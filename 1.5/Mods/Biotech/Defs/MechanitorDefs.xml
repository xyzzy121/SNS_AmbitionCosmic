      <MoveSpeed>5.3</MoveSpeed>
      <ArmorRating_Blunt>0.40</ArmorRating_Blunt>
      <ArmorRating_Sharp>0.60</ArmorRating_Sharp>
    </statBases>
    <butcherProducts>
      <SNS_Unobtainium>15</SNS_Unobtainium>
    </butcherProducts>
  </ThingDef>
    </Thingdef>
</defs>
 